---
import Layout from "../components/Layout.astro";
---

<Layout
  title="Contact"
  description="Get in touch with AP Dev Pro — start a project, ask a question, or discuss your cloud architecture and automation needs."
  ogUrl="https://apcloud.pro/contact"
>
  <section class="pb-16 pt-24 sm:pb-20 sm:pt-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-xs font-semibold uppercase tracking-wider text-electric-400">Contact</p>
        <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-100 sm:text-5xl text-balance">
          Let's start a conversation
        </h1>
        <p class="mt-6 text-base leading-relaxed text-slate-400 text-balance">
          Fill out the form below and I'll get back to you within one business day. No automated replies — every message goes straight to me.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-20 sm:pb-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Form -->
        <div class="lg:col-span-3">
          <div class="rounded-xl border border-slate-800 bg-navy-900 p-6 sm:p-8">
            <form action="#" method="POST" class="space-y-5">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-300">
                  Name <span class="text-electric-400">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="mt-1.5 block w-full rounded-lg border border-slate-700 bg-navy-900 px-4 py-2.5 text-sm text-slate-200 placeholder-slate-500 transition-colors focus:border-electric-500/50 focus:outline-none focus:ring-1 focus:ring-electric-500/20"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-slate-300">
                  Email <span class="text-electric-400">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="you@example.com"
                  class="mt-1.5 block w-full rounded-lg border border-slate-700 bg-navy-900 px-4 py-2.5 text-sm text-slate-200 placeholder-slate-500 transition-colors focus:border-electric-500/50 focus:outline-none focus:ring-1 focus:ring-electric-500/20"
                />
              </div>

              <div>
                <label for="projectType" class="block text-sm font-medium text-slate-300">
                  Project Type
                </label>
                <select
                  id="projectType"
                  name="projectType"
                  class="mt-1.5 block w-full rounded-lg border border-slate-700 bg-navy-900 px-4 py-2.5 text-sm text-slate-200 transition-colors focus:border-electric-500/50 focus:outline-none focus:ring-1 focus:ring-electric-500/20"
                >
                  <option value="" disabled selected>Select a type...</option>
                  <option value="serverless">Serverless Architecture</option>
                  <option value="fullstack">Full-Stack Development</option>
                  <option value="devops">Cloud Automation / DevOps</option>
                  <option value="ai">AI / Automation Workflows</option>
                  <option value="modernization">Legacy Modernization</option>
                  <option value="review">Architecture Review</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-300">
                  Message <span class="text-electric-400">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows={6}
                  placeholder="Tell me about your project, timeline, budget — anything that helps me understand what you need."
                  class="mt-1.5 block w-full rounded-lg border border-slate-700 bg-navy-900 px-4 py-2.5 text-sm text-slate-200 placeholder-slate-500 transition-colors focus:border-electric-500/50 focus:outline-none focus:ring-1 focus:ring-electric-500/20 resize-y"
                ></textarea>
              </div>

              <button
                type="submit"
                class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-gradient-to-r from-electric-500 to-violet-500 px-6 py-3 text-sm font-semibold text-white transition-all duration-200 hover:from-electric-400 hover:to-violet-400 hover:shadow-lg hover:shadow-electric-500/20 sm:w-auto"
              >
                Send Message
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                </svg>
              </button>
            </form>

            <p class="mt-5 rounded-lg border border-amber-500/10 bg-amber-500/5 px-4 py-3 text-xs leading-relaxed text-slate-500">
              <span class="font-semibold text-amber-400/80">Note:</span>
              This form is currently a static placeholder.
              To receive submissions, wire it up to
              <a href="https://formspree.io" class="underline decoration-slate-600 hover:text-amber-300">Formspree</a>,
              a <span class="text-slate-400">Cloudflare Worker</span>, or another form backend.
              See the source comments for setup instructions.
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:col-span-2 space-y-6">
          <div class="rounded-xl border border-slate-800 bg-navy-900 p-5">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400">Other Ways to Reach Me</h3>
            <ul class="mt-4 space-y-4">
              <li>
                <p class="text-xs text-slate-500">Email</p>
                <a href="mailto:hello@apdev.pro" class="text-sm text-slate-300 transition-colors hover:text-electric-400">
                  hello@apdev.pro
                </a>
              </li>
            </ul>
          </div>

          <div class="rounded-xl border border-slate-800 bg-navy-900 p-5">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400">What Happens Next</h3>
            <ol class="mt-4 space-y-3">
              <li class="flex gap-3">
                <span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-electric-500/10 text-xs text-electric-400">1</span>
                <span class="text-sm text-slate-400">I'll review your message and respond within one business day.</span>
              </li>
              <li class="flex gap-3">
                <span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-electric-500/10 text-xs text-electric-400">2</span>
                <span class="text-sm text-slate-400">We'll schedule a free 30-minute call to discuss your project in detail.</span>
              </li>
              <li class="flex gap-3">
                <span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-electric-500/10 text-xs text-electric-400">3</span>
                <span class="text-sm text-slate-400">If it's a good fit, I'll send a proposal with scope, timeline, and pricing.</span>
              </li>
            </ol>
          </div>

          <div class="rounded-xl border border-slate-800 bg-navy-900 p-5">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-400">Availability</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">
              Currently accepting new projects. Typical engagement starts at 2-4 weeks for an initial build or migration. Longer-term retainers available for ongoing work.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
