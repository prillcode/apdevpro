---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-800 bg-navy-900/50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 text-lg font-bold tracking-tight">
          <span class="flex h-8 w-8 items-center justify-center rounded-md bg-gradient-to-br from-electric-500 to-violet-500 text-xs font-bold text-white">
            AP
          </span>
          <span class="bg-gradient-to-r from-electric-400 via-cyan-400 to-violet-400 bg-clip-text text-transparent">AP Dev Pro</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-slate-400">
          Modern software engineering, serverless architecture, and AI-powered automation consulting.
        </p>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Pages</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-slate-400 transition-colors hover:text-slate-200">Home</a></li>
          <li><a href="/services" class="text-sm text-slate-400 transition-colors hover:text-slate-200">Services</a></li>
          <li><a href="/work" class="text-sm text-slate-400 transition-colors hover:text-slate-200">Work</a></li>
          <li><a href="/about" class="text-sm text-slate-400 transition-colors hover:text-slate-200">About</a></li>
          <li><a href="/contact" class="text-sm text-slate-400 transition-colors hover:text-slate-200">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Services</h3>
        <ul class="space-y-2">
          <li><span class="text-sm text-slate-500">Serverless Architecture</span></li>
          <li><span class="text-sm text-slate-500">Full-Stack Development</span></li>
          <li><span class="text-sm text-slate-500">Cloud Automation & DevOps</span></li>
          <li><span class="text-sm text-slate-500">AI Workflow Design</span></li>
          <li><a href="/services" class="text-sm text-electric-400 transition-colors hover:text-electric-300">View all →</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Contact</h3>
        <ul class="space-y-2">
          <li><a href="mailto:hello@apdev.pro" class="text-sm text-slate-400 transition-colors hover:text-slate-200">hello@apdev.pro</a></li>
          <li><a href="/contact" class="text-sm text-slate-400 transition-colors hover:text-slate-200">Start a project</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-slate-800 pt-6 sm:flex-row">
      <p class="text-xs text-slate-500">
        &copy; {currentYear} AP Dev Pro. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <span class="text-xs text-slate-600">apcloud.pro</span>
        <span class="text-xs text-slate-600">apdev.pro</span>
      </div>
    </div>
  </div>
</footer>
