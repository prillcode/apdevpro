---
export interface Props {
  title: string;
  description: string;
  icon: string;
  technologies?: string[];
  href?: string;
}

const { title, description, icon, technologies = [], href } = Astro.props;
---

<div class="rounded-xl border border-slate-800 bg-navy-900 transition-all duration-200 hover:border-slate-700 hover:bg-navy-800 group flex flex-col p-6">
  <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-electric-500/10 text-xl">
    {icon}
  </div>

  {href ? (
    <a href={href} class="text-base font-semibold text-slate-200 transition-colors group-hover:text-electric-400">
      {title}
    </a>
  ) : (
    <h3 class="text-base font-semibold text-slate-200">{title}</h3>
  )}

  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-400">
    {description}
  </p>

  {technologies.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {technologies.map((tech) => (
        <span class="rounded-md bg-slate-800 px-2 py-0.5 text-xs text-slate-400">
          {tech}
        </span>
      ))}
    </div>
  )}
</div>
